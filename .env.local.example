# Pasar DANA — environment variables (Phase 0)
#
# Copy this file to `.env.local` inside `web/` for local development, and set
# the same vars in Vercel Project Settings for catatanbelanja.vercel.app.
#
# Public vars are exposed to the browser bundle.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER prefix with NEXT_PUBLIC_. Used by Edge Functions and
# server-side admin operations only. Do not import from a Client Component.
SUPABASE_SERVICE_ROLE_KEY=
